FROM sagemath/sagemath:10.5

USER root

RUN apt update && \
	apt install -y socat
RUN rm -rf /var/cache/apt/archives /var/lib/apt/lists/*

WORKDIR /home/sage/
COPY chall.sage ./
RUN sage --preparse chall.sage
RUN chmod +x chall.sage.py

EXPOSE 1337

USER sage

CMD ["socat", "TCP-LISTEN:1337,reuseaddr,fork", "EXEC:\"sage -python chall.sage.py\""]
