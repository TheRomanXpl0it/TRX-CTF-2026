<section class="hero">
    <div class="container">
        <h1>Whois Lookup</h1>
        <p>Everything starts with a domain name. Find yours today.</p>
        <form action="/lookup" method="POST" class="search-form">
            <div class="search-box">
                <input type="text" name="domain" placeholder="Enter a domain name (e.g. example.com)" required pattern="[a-z.-]+">
                <button type="submit">SEARCH</button>
            </div>
            <div class="examples">
                <span>Examples: </span>
                <code>google.com</code>, <code>theromanxpl0.it</code>, <code>tenor.com</code>
            </div>
        </form>
    </div>
</section>

<section class="features">
    <div class="container">
        <div class="feature">
            <h3>Fast & Precise</h3>
            <p>Direct access to WHOIS databases</p>
        </div>
        <div class="feature">
            <h3>Detailed Reports</h3>
            <p>Comprehensive information about domain registration.</p>
        </div>
        <div class="feature">
            <h3>Secure</h3>
            <p>Validated lookups ensuring system integrity.</p>
        </div>
    </div>
</section>
